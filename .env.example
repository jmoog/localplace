# Copier ce fichier en .env et remplir les valeurs.
# .env est ignoré par git — les secrets ne quittent jamais la machine.

# PostgreSQL (Coolify en prod, instance locale en dev)
DATABASE_URL=postgres://localplace:motdepasse@localhost:5432/localplace

# Brevo — email transactionnel (optionnel en dev)
BREVO_API_KEY=
